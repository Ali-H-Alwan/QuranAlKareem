<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── لوحة الألوان ── -->
    <Color x:Key="GreenColor">#0E5A3C</Color>
    <SolidColorBrush x:Key="Green" Color="#0E5A3C" />
    <SolidColorBrush x:Key="GreenDark" Color="#0A3F2A" />
    <SolidColorBrush x:Key="GreenLight" Color="#13724C" />
    <SolidColorBrush x:Key="Gold" Color="#C9A24B" />
    <SolidColorBrush x:Key="GoldSoft" Color="#E6D9B8" />
    <SolidColorBrush x:Key="Parchment" Color="#F6F1E6" />
    <SolidColorBrush x:Key="Card" Color="#FFFFFF" />
    <SolidColorBrush x:Key="CardAlt" Color="#FBF8F1" />
    <SolidColorBrush x:Key="Ink" Color="#1C1C1C" />
    <SolidColorBrush x:Key="Muted" Color="#8A7B5F" />

    <!-- ── زر مسطّح أساسي ── -->
    <Style x:Key="FlatButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource Green}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{StaticResource GreenLight}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="b" Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── زر ذهبي ── -->
    <Style x:Key="GoldButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
        <Setter Property="Background" Value="{StaticResource Gold}" />
    </Style>

    <!-- ── زر شفّاف صغير (نسخ/صفحة) ── -->
    <Style x:Key="LinkButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource Green}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{StaticResource GoldSoft}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── زر الكلمة (للإعراب) ── -->
    <Style x:Key="WordButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource Ink}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="3,1" />
        <Setter Property="Margin" Value="2,1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="ToolTip" Value="اضغط لعرض الإعراب" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{StaticResource GoldSoft}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── رقاقة معلومات (chip) ── -->
    <Style x:Key="Chip" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardAlt}" />
        <Setter Property="BorderBrush" Value="{StaticResource GoldSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="10,3" />
        <Setter Property="Margin" Value="0,0,6,0" />
    </Style>

    <!-- ── بطاقة ── -->
    <Style x:Key="CardPanel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Card}" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="14" />
    </Style>

</ResourceDictionary>
