<UserControl x:Class="QuranAlKareem.App.Views.SearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             Background="{StaticResource Parchment}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="280" />
        </Grid.ColumnDefinitions>

        <!-- ═══ الترويسة ═══ -->
        <Border Grid.Row="0" Grid.ColumnSpan="3" CornerRadius="12" Margin="0,0,0,12">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0A3F2A" Offset="0" />
                    <GradientStop Color="#13724C" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="18,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="﴿" Foreground="{StaticResource Gold}" FontSize="30" VerticalAlignment="Center" />
                    <TextBlock Text="القرآن الكريم" Foreground="White" FontSize="24" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="6,0" />
                    <TextBlock Text="﴾" Foreground="{StaticResource Gold}" FontSize="30" VerticalAlignment="Center" />
                </StackPanel>

                <!-- البحث -->
                <Border Grid.Column="1" Background="#1A6B49" CornerRadius="8" Margin="20,0" Padding="6,4"
                        VerticalAlignment="Center" MaxWidth="520">
                    <DockPanel>
                        <Button DockPanel.Dock="Left" Content="🔍 بحث" Command="{Binding SearchCommand}"
                                Style="{StaticResource GoldButton}" Margin="6,0,0,0" />
                        <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="كلمة" GroupName="ModeMain" Foreground="White" VerticalAlignment="Center"
                                             IsChecked="{Binding Mode, Converter={StaticResource EnumBool}, ConverterParameter=Word, Mode=TwoWay}" />
                                <RadioButton Content="جزء" GroupName="ModeMain" Foreground="White" VerticalAlignment="Center"
                                             Margin="10,0,0,0" ToolTip="جزء من كلمة"
                                             IsChecked="{Binding Mode, Converter={StaticResource EnumBool}, ConverterParameter=Part, Mode=TwoWay}" />
                                <RadioButton Content="جذر" GroupName="ModeMain" Foreground="White" VerticalAlignment="Center"
                                             Margin="10,0,0,0"
                                             IsChecked="{Binding Mode, Converter={StaticResource EnumBool}, ConverterParameter=Root, Mode=TwoWay}" />
                            </StackPanel>
                            <CheckBox Content="تظليل النتائج" IsChecked="{Binding HighlightMatches}"
                                      Foreground="#CFE6DA" Margin="0,5,0,0" />
                        </StackPanel>
                        <!-- حقل إدخال كلمة البحث (مع نص إرشادي يظهر عند الفراغ) -->
                        <Grid MinWidth="220">
                            <TextBox x:Name="SearchBox"
                                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                     Background="White" BorderThickness="0" FontSize="15" Padding="8,6"
                                     MinHeight="34" VerticalContentAlignment="Center">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding SearchCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>
                            <TextBlock Text="اكتب كلمة البحث…" Foreground="#9AA8A0" FontSize="15"
                                       Margin="10,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- اقتراحات البحث (autocomplete) -->
                            <Popup x:Name="SuggestPopup" PlacementTarget="{Binding ElementName=SearchBox}"
                                   Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
                                   Width="{Binding ActualWidth, ElementName=SearchBox}">
                                <Border Background="White" BorderBrush="{StaticResource GoldSoft}"
                                        BorderThickness="1" CornerRadius="6" Margin="0,2,0,0">
                                    <ListBox x:Name="SuggestList" MaxHeight="300" BorderThickness="0"
                                             FlowDirection="RightToLeft" FontSize="15">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="10,6" />
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <DockPanel>
                                                    <TextBlock DockPanel.Dock="Left" Text="{Binding Count}"
                                                               Foreground="{StaticResource Muted}" FontSize="12"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding Text}" FontWeight="Bold"
                                                               Foreground="{StaticResource Ink}" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding Root}" Foreground="{StaticResource Green}"
                                                               FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center" />
                                                </DockPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </Popup>
                        </Grid>
                    </DockPanel>
                </Border>

                <!-- الخط والحجم والإعدادات -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="الخط" Foreground="#CFE6DA" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox Width="170" ItemsSource="{Binding Fonts}" SelectedItem="{Binding SelectedFont}"
                              VerticalAlignment="Center" />
                    <TextBlock Text="الحجم" Foreground="#CFE6DA" VerticalAlignment="Center" Margin="10,0,6,0" />
                    <Slider Width="110" Minimum="16" Maximum="54" Value="{Binding FontSize}"
                            VerticalAlignment="Center" Margin="0,0,0,0" />

                    <Button Content="⚙ إعدادات" Style="{StaticResource FlatButton}" Background="#1A6B49"
                            Margin="10,0,0,0" Command="{Binding ToggleSettingsCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ قائمة السور ═══ -->
        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardPanel}" Padding="6" Margin="0,0,12,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="السور" FontWeight="Bold" Foreground="{StaticResource Green}"
                           FontSize="15" Margin="8,6,8,8" />
                <ListBox ItemsSource="{Binding Surahs}" SelectedItem="{Binding SelectedSurah}"
                         BorderThickness="0" Background="Transparent" FontSize="15">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="8,6" />
                            <Setter Property="Margin" Value="2,1" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel>
                                <Border DockPanel.Dock="Right" Background="{StaticResource GoldSoft}" CornerRadius="10"
                                        Width="26" Height="22" Margin="0,0,2,0">
                                    <TextBlock Text="{Binding Number}" FontSize="11" HorizontalAlignment="Center"
                                               VerticalAlignment="Center" Foreground="{StaticResource GreenDark}" />
                                </Border>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ═══ النتائج + الإعراب ═══ -->
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource CardPanel}" Padding="6">
                <ListBox x:Name="ResultsList" ItemsSource="{Binding Ayahs}" BorderThickness="0"
                         Background="Transparent" HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Margin" Value="0,3" />
                            <!-- منع القائمة من القفز/التمرير التلقائي عند النقر داخل عنصر -->
                            <EventSetter Event="RequestBringIntoView" Handler="OnItemRequestBringIntoView" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource CardAlt}" CornerRadius="8" Padding="14,10"
                                    BorderBrush="{StaticResource GoldSoft}" BorderThickness="1">
                                <StackPanel>
                                    <DockPanel LastChildFill="False">
                                        <Border DockPanel.Dock="Right" Style="{StaticResource Chip}"
                                                Background="{StaticResource Green}" BorderThickness="0"
                                                Visibility="{Binding HasMatchLabel, Converter={StaticResource BoolToVisibility}}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="الجذر: " Foreground="#CFE6DA" FontSize="12" />
                                                <TextBlock Text="{Binding MatchLabel}" Foreground="White"
                                                           FontSize="13" FontWeight="Bold" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource Chip}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="سورة " Foreground="{StaticResource Muted}" FontSize="12" />
                                                <TextBlock Text="{Binding SurahName}" Foreground="{StaticResource Green}"
                                                           FontSize="13" FontWeight="Bold" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource Chip}">
                                            <TextBlock FontSize="12" Foreground="{StaticResource Ink}">
                                                <Run Text="الآية" Foreground="{StaticResource Muted}" />
                                                <Run Text="{Binding NumberInSurah, Mode=OneWay}" FontWeight="Bold" />
                                            </TextBlock>
                                        </Border>
                                        <Border Style="{StaticResource Chip}">
                                            <TextBlock FontSize="12" Foreground="{StaticResource Ink}">
                                                <Run Text="الصفحة" Foreground="{StaticResource Muted}" />
                                                <Run Text="{Binding Page, Mode=OneWay}" FontWeight="Bold" />
                                            </TextBlock>
                                        </Border>

                                        <Button DockPanel.Dock="Left" Content="نسخ" Style="{StaticResource LinkButton}"
                                                Command="{Binding DataContext.CopyAyahCommand,
                                                          RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}" />
                                        <Button DockPanel.Dock="Left" Content="فتح الصفحة" Style="{StaticResource LinkButton}"
                                                Foreground="{StaticResource Gold}"
                                                Command="{Binding DataContext.OpenPageCommand,
                                                          RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}" />
                                    </DockPanel>

                                    <Border Margin="0,8,0,0" Padding="6,4" Background="White" CornerRadius="6">
                                        <ItemsControl ItemsSource="{Binding Words}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Content="{Binding Form}" Style="{StaticResource WordButton}"
                                                            Command="{Binding DataContext.ShowWordAnalysisCommand,
                                                                      RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                            CommandParameter="{Binding}"
                                                            FontFamily="{Binding DataContext.SelectedFont,
                                                                        RelativeSource={RelativeSource AncestorType=ListBox},
                                                                        Converter={StaticResource FontResolver}}"
                                                            FontSize="{Binding DataContext.FontSize,
                                                                       RelativeSource={RelativeSource AncestorType=ListBox}}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Border Grid.Row="1" CornerRadius="10" Margin="0,12,0,0" Padding="14" MaxHeight="320"
                    Background="{StaticResource GreenDark}"
                    Visibility="{Binding AnalysisTitle, Converter={StaticResource NonEmptyToVisibility}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="{Binding AnalysisTitle}" Foreground="{StaticResource Gold}" FontWeight="Bold"
                               FontSize="15" Margin="0,0,0,4" />
                    <TextBlock Text="إعراب الكلمة (نوعها وحالتها وعلامة إعرابها):" Foreground="#9FC4B2"
                               FontSize="11" Margin="0,0,0,8" />
                    <ItemsControl ItemsSource="{Binding Analysis}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource GreenLight}" CornerRadius="8" Margin="4" Padding="10,7">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Form}" Foreground="White" FontSize="20"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="{Binding Description}" Foreground="{StaticResource GoldSoft}"
                                                   FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"
                                                   MaxWidth="220" TextWrapping="Wrap" TextAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Background="#0A3F2A" CornerRadius="8" Padding="10" Margin="0,10,0,0"
                            Visibility="{Binding TafsirText, Converter={StaticResource NonEmptyToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="التفسير الميسَّر" Foreground="{StaticResource Gold}"
                                       FontWeight="Bold" FontSize="13" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding TafsirText}" Foreground="#E6F0EA" FontSize="13"
                                       TextWrapping="Wrap" LineHeight="22" />
                        </StackPanel>
                    </Border>
                </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ═══ شريط الإحصائيات ═══ -->
        <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource CardPanel}" Margin="12,0,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="إحصائية البحث" FontWeight="Bold"
                           Foreground="{StaticResource Green}" FontSize="15" Margin="2,2,2,10" />

                <StackPanel DockPanel.Dock="Top"
                            Visibility="{Binding HasStats, Converter={StaticResource BoolToVisibility}}">
                    <Border CornerRadius="8" Padding="12,10" Margin="0,0,0,8" Background="{StaticResource Green}">
                        <StackPanel>
                            <TextBlock Text="{Binding StatAyahCount}" Foreground="White" FontSize="28" FontWeight="Bold"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="آية تحتوي البحث" Foreground="#CFE6DA" FontSize="12"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border CornerRadius="8" Padding="12,10" Margin="0,0,0,8" Background="{StaticResource Gold}">
                        <StackPanel>
                            <TextBlock Text="{Binding StatSurahCount}" Foreground="White" FontSize="28" FontWeight="Bold"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="سورة ظهر فيها" Foreground="#FBF3DD" FontSize="12"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Chip}" Margin="0,0,0,10" HorizontalAlignment="Stretch">
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource Ink}">
                            <Run Text="الجذور: " Foreground="{StaticResource Muted}" />
                            <Run Text="{Binding StatRoots, Mode=OneWay}" FontWeight="Bold" />
                        </TextBlock>
                    </Border>

                    <TextBlock Text="التوزيع حسب السور (الأعلى)" Foreground="{StaticResource Muted}"
                               FontSize="12" Margin="2,0,2,6" />
                </StackPanel>

                <ItemsControl ItemsSource="{Binding SurahStats}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,5">
                                <!-- الاسم كاملاً + العدد -->
                                <DockPanel>
                                    <Border DockPanel.Dock="Left" Background="{StaticResource Green}"
                                            CornerRadius="9" MinWidth="24" Padding="6,1">
                                        <TextBlock Text="{Binding Count}" Foreground="White" FontWeight="Bold"
                                                   FontSize="12" HorizontalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="{Binding SurahName}" Foreground="{StaticResource Ink}"
                                               FontSize="13" FontWeight="Bold" VerticalAlignment="Center"
                                               Margin="0,0,4,0" TextTrimming="None" />
                                </DockPanel>
                                <!-- شريط نسبي رفيع -->
                                <Border Background="#EFE7D2" CornerRadius="4" Height="8" Margin="0,4,0,0">
                                    <Border HorizontalAlignment="Right" Background="{StaticResource GreenLight}"
                                            CornerRadius="4"
                                            Width="{Binding Ratio, Converter={StaticResource RatioToWidth}}" />
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <!-- ═══ شريط الحالة ═══ -->
        <Border Grid.Row="2" Grid.ColumnSpan="3" Margin="0,12,0,0">
            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource Green}" FontSize="13" />
        </Border>
    </Grid>
</UserControl>
