<UserControl x:Class="QuranAlKareem.App.Views.MushafView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             Background="#EFE7D2">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ترويسة -->
        <Border Grid.Row="0" Background="#0E5A3C" CornerRadius="8" Padding="12,8" Margin="0,0,0,10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox Content="عرض صفحتين" IsChecked="{Binding TwoPages}"
                              Foreground="White" VerticalAlignment="Center" />
                    <TextBlock Text="الخط:" Foreground="#CFE6DA" VerticalAlignment="Center" Margin="16,0,6,0" />
                    <ComboBox Width="185" ItemsSource="{Binding Fonts}" SelectedItem="{Binding SelectedFont}"
                              VerticalAlignment="Center" />
                    <TextBlock Text="حجم الخط:" Foreground="#CFE6DA" VerticalAlignment="Center" Margin="16,0,6,0" />
                    <Button Content="−" Command="{Binding ZoomOutCommand}" Width="30" Height="28"
                            Background="#1A6B49" Foreground="White" BorderThickness="0" FontSize="16" Cursor="Hand" />
                    <Button Content="+" Command="{Binding ZoomInCommand}" Width="30" Height="28" Margin="4,0,0,0"
                            Background="#1A6B49" Foreground="White" BorderThickness="0" FontSize="16" Cursor="Hand" />

                    <Border Width="1" Background="#2E7D5A" Margin="14,4" />
                    <Button x:Name="CopySelBtn" Content="نسخ المحدَّد" Click="OnCopySelection" IsEnabled="False"
                            Style="{StaticResource FlatButton}" Background="#C9A24B" Padding="10,5" FontSize="12"
                            ToolTip="Ctrl + نقر على الكلمات لتحديد جزء من الآية ثم نسخه" />
                    <Button x:Name="ClearSelBtn" Content="مسح التحديد" Click="OnClearSelection" IsEnabled="False"
                            Style="{StaticResource FlatButton}" Background="#1A6B49" Padding="10,5" FontSize="12"
                            Margin="6,0,0,0" />
                    <TextBlock Text="Ctrl+نقر لتحديد" Foreground="#8FBFA6" FontSize="10"
                               VerticalAlignment="Center" Margin="8,0,0,0" />
                </StackPanel>
                <TextBlock DockPanel.Dock="Right" Text="{Binding CopyNotice}" Foreground="#7DE0B0"
                           FontSize="13" VerticalAlignment="Center" Margin="0,0,12,0" />
                <TextBlock Text="{Binding RightHeader}" Foreground="#C9A24B" FontSize="16" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- ═══ وضع الصفحة الواحدة: صفحة + شريط جانبي ═══ -->
        <Grid Grid.Row="1" Visibility="{Binding TwoPages, Converter={StaticResource InverseBoolToVisibility}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <Border x:Name="SingleCard" Grid.Column="0" Background="#FFFDF6" CornerRadius="10"
                    BorderBrush="#C9A24B" BorderThickness="2" Padding="26" RenderTransformOrigin="0.5,0.5">
                <Border.Effect>
                    <DropShadowEffect Color="#8A7B4F" BlurRadius="18" ShadowDepth="0" Opacity="0.5" />
                </Border.Effect>
                <Border.RenderTransform>
                    <ScaleTransform x:Name="SingleScale" ScaleX="1" ScaleY="1" />
                </Border.RenderTransform>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="SingleText" TextAlignment="Justify" TextWrapping="Wrap" Foreground="#1A1A1A" />
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1" Margin="12,0,0,0" Background="White" CornerRadius="10" Padding="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="معلومات الصفحة" FontWeight="Bold" FontSize="16"
                                   Foreground="#0E5A3C" Margin="0,0,0,12" />

                        <Border Background="#0E5A3C" CornerRadius="8" Padding="12,10" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="{Binding PageInfo.Page}" Foreground="White" FontSize="30"
                                           FontWeight="Bold" HorizontalAlignment="Center" />
                                <TextBlock Text="رقم الصفحة" Foreground="#CFE6DA" FontSize="12"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <UniformGrid Columns="2" Margin="0,0,0,8">
                            <Border Background="#C9A24B" CornerRadius="8" Padding="8" Margin="0,0,4,4">
                                <StackPanel>
                                    <TextBlock Text="{Binding PageInfo.AyahCount}" Foreground="White"
                                               FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />
                                    <TextBlock Text="آية" Foreground="#FBF3DD" FontSize="11" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Background="#13724C" CornerRadius="8" Padding="8" Margin="4,0,0,4">
                                <StackPanel>
                                    <TextBlock Text="{Binding PageInfo.WordCount}" Foreground="White"
                                               FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />
                                    <TextBlock Text="كلمة" Foreground="#CFE6DA" FontSize="11" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Background="#13724C" CornerRadius="8" Padding="8" Margin="0,4,4,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding PageInfo.LetterCount}" Foreground="White"
                                               FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />
                                    <TextBlock Text="حرف" Foreground="#CFE6DA" FontSize="11" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Background="#C9A24B" CornerRadius="8" Padding="8" Margin="4,4,0,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding PageInfo.SajdaCount}" Foreground="White"
                                               FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />
                                    <TextBlock Text="سجدة" Foreground="#FBF3DD" FontSize="11" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <TextBlock Text="السور في الصفحة" Foreground="#8A7B5F" FontSize="12" Margin="2,8,0,4" />
                        <ItemsControl ItemsSource="{Binding PageInfo.Surahs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FBF8F1" CornerRadius="6" Padding="8,5" Margin="0,2"
                                            BorderBrush="#E6D9B8" BorderThickness="1">
                                        <TextBlock Text="{Binding}" Foreground="#0E5A3C" FontWeight="Bold" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="الجزء والحزب" Foreground="#8A7B5F" FontSize="12" Margin="2,10,0,4" />
                        <ItemsControl ItemsSource="{Binding PageInfo.Juz}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#1A1A1A" Margin="2,1" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding PageInfo.HizbQuarters}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#8A7B5F" FontSize="12" Margin="2,1" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Margin="0,12,0,8" />
                        <TextBlock Text="التلاوة (ترتيل)" Foreground="#0E5A3C" FontWeight="Bold"
                                   FontSize="13" Margin="2,0,0,6" />
                        <ComboBox ItemsSource="{Binding Reciters}" SelectedItem="{Binding SelectedReciter}" />
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="▶ تشغيل الصفحة" Command="{Binding PlayPageCommand}"
                                    Background="#0E5A3C" Foreground="White" BorderThickness="0"
                                    Padding="10,6" Cursor="Hand" />
                            <Button Content="■ إيقاف" Command="{Binding StopAudioCommand}"
                                    Background="#C9A24B" Foreground="White" BorderThickness="0"
                                    Padding="10,6" Margin="6,0,0,0" Cursor="Hand" />
                        </StackPanel>
                        <TextBlock Text="{Binding AudioStatus}" Foreground="#0E5A3C" FontSize="12"
                                   FontWeight="Bold" Margin="2,6,0,0"
                                   Visibility="{Binding AudioStatus, Converter={StaticResource NonEmptyToVisibility}}" />
                        <TextBlock Text="(يُحمَّل الصوت أول مرة ثم يعمل بدون إنترنت)" Foreground="#8A7B5F"
                                   FontSize="10" Margin="2,4,0,0" TextWrapping="Wrap" />

                        <Border Background="#0A3F2A" CornerRadius="8" Padding="12" Margin="0,12,0,0"
                                Visibility="{Binding AnalysisTitle, Converter={StaticResource NonEmptyToVisibility}}">
                            <StackPanel>
                                <TextBlock Text="{Binding AnalysisTitle}" Foreground="#C9A24B"
                                           FontWeight="Bold" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,8" />
                                <ItemsControl ItemsSource="{Binding Analysis}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#13724C" CornerRadius="6" Margin="0,3" Padding="8,6">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Form}" Foreground="White"
                                                               FontSize="18" HorizontalAlignment="Center" />
                                                    <TextBlock Text="{Binding Description}" Foreground="#E6D9B8"
                                                               FontSize="12" TextWrapping="Wrap"
                                                               TextAlignment="Center" Margin="0,3,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Background="#FBF8F1" CornerRadius="8" Padding="12" Margin="0,10,0,0"
                                BorderBrush="#E6D9B8" BorderThickness="1"
                                Visibility="{Binding TafsirText, Converter={StaticResource NonEmptyToVisibility}}">
                            <StackPanel>
                                <TextBlock Text="التفسير الميسَّر" Foreground="#0E5A3C" FontWeight="Bold"
                                           FontSize="13" Margin="0,0,0,6" />
                                <TextBlock Text="{Binding TafsirText}" Foreground="#1A1A1A" FontSize="13"
                                           TextWrapping="Wrap" LineHeight="22" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ═══ وضع الصفحتين ═══ -->
        <Grid Grid.Row="1" Visibility="{Binding TwoPages, Converter={StaticResource BoolToVisibility}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FFFDF6" CornerRadius="10" Margin="0,0,6,0"
                    BorderBrush="#C9A24B" BorderThickness="2" Padding="22">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Bottom" Text="{Binding RightHeader}" Foreground="#9A8C6A"
                               FontSize="11" HorizontalAlignment="Center" Margin="0,8,0,0" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="TwoRightText" TextAlignment="Justify" TextWrapping="Wrap" Foreground="#1A1A1A" />
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Background="#FFFDF6" CornerRadius="10" Margin="6,0,0,0"
                    BorderBrush="#C9A24B" BorderThickness="2" Padding="22">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Bottom" Text="{Binding LeftHeader}" Foreground="#9A8C6A"
                               FontSize="11" HorizontalAlignment="Center" Margin="0,8,0,0" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="TwoLeftText" TextAlignment="Justify" TextWrapping="Wrap" Foreground="#1A1A1A" />
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
            <Button Content="◄ السابقة" Command="{Binding PreviousPageCommand}"
                    Padding="16,8" Margin="6,0" Background="#0E5A3C" Foreground="White" BorderThickness="0" />
            <Button Content="التالية ►" Command="{Binding NextPageCommand}"
                    Padding="16,8" Margin="6,0" Background="#0E5A3C" Foreground="White" BorderThickness="0" />
        </StackPanel>
    </Grid>
</UserControl>
