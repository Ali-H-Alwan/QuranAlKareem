<Window x:Class="QuranAlKareem.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="القرآن الكريم" Height="780" Width="1240"
        Icon="pack://application:,,,/QuranAlKareem.App;component/quran.ico"
        FlowDirection="RightToLeft"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Parchment}">

    <TabControl x:Name="Tabs" Background="{StaticResource Parchment}" BorderThickness="0" Padding="0">
        <TabControl.Resources>
            <!-- شكل رأس التبويب (مثل تبويبات كروم) -->
            <Style TargetType="TabItem">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border x:Name="b" CornerRadius="8,8,0,0" Margin="2,4,2,0"
                                    Background="#DCCBA0" Padding="10,6"
                                    TextBlock.Foreground="#0A3F2A">
                                <ContentPresenter ContentSource="Header" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="#0E5A3C" />
                                    <Setter TargetName="b" Property="TextBlock.Foreground" Value="White" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </TabControl.Resources>
    </TabControl>
</Window>
